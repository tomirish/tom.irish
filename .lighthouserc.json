{
  "ci": {
    "collect": {
      "url": ["https://tom.irish/"],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance":     ["warn",  { "minScore": 0.95 }],
        "categories:accessibility":   ["error", { "minScore": 1.0  }],
        "categories:best-practices":  ["warn",  { "minScore": 0.9  }],
        "categories:seo":             ["error", { "minScore": 1.0  }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
